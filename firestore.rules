rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 200;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.uid == resource.data.uid;

      // Sub-collections
      match /documents/{docId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.name is string && request.resource.data.name.size() <= 255;
        allow update: if isOwner(userId) 
          && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }

      match /reports/{reportId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /simulations/{simId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
